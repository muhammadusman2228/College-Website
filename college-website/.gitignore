# ─────────────────────────────────────────────────────────
#  .gitignore – Greenfield College Website
# ─────────────────────────────────────────────────────────

# ── Security / Secrets (NEVER commit these) ─────────────
server/.env
server/.env.*
*.env
.env.local
.env.production

# ── Database files (contains student PII) ───────────────
server/db/college.db
server/db/*.db
*.db
*.sqlite
*.sqlite3

# ── Node.js ─────────────────────────────────────────────
server/node_modules/
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm

# ── OS / Editor ─────────────────────────────────────────
.DS_Store
Thumbs.db
*.log
.vscode/settings.json
.idea/

# ── Build artifacts ─────────────────────────────────────
dist/
build/
.cache/

# ── Brain / AI artifacts (internal only) ───────────────
.gemini/
